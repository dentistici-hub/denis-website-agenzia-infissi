---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, nav, schema, services, testimonials, faqs } from '../data/placeholder';

const description = 'M2E Marketing costruisce landing page, campagne e sistemi di follow-up per aziende di infissi e serramenti che vogliono preventivi qualificati, tracciamento e appuntamenti commerciali reali.';
const basePath = import.meta.env.BASE_URL;
const withBase = (path: string) => `${basePath.replace(/\/?$/, '/')}${path.replace(/^\//, '')}`;
const logoImage = withBase('/images/m2e-logo-cropped.png');
const heroImage = withBase('/images/hero-showroom-pipeline.webp');
const ogImage = `${site.url}/images/og-m2e-infissi.webp`;

const channels = [
  { label: 'Google Search', value: 'Domanda calda: sostituzione infissi, preventivo, posa certificata.' },
  { label: 'Meta locale', value: 'Domanda latente: riqualificazione, isolamento, showroom e offerte stagionali.' },
  { label: 'SEO + AI search', value: 'Contenuti utili per bonus, materiali, posa, trasmittanza e zone servite.' },
  { label: 'CRM/WhatsApp', value: 'Richieste ordinate per priorità, tempo di risposta e prossima azione.' },
];

const process = [
  { step: '01', title: 'Diagnosi del margine', text: 'Separiamo prodotti da spingere, zone da servire, cantieri da evitare e obiettivi commerciali reali.' },
  { step: '02', title: 'Pagina verticale', text: 'Costruiamo messaggio, prova, obiezioni e modulo per il tipo di richiesta che vuoi ricevere.' },
  { step: '03', title: 'Traffico misurabile', text: 'Campagne divise per intento, materiale, urgenza e area geografica. Niente calderone mistico.' },
  { step: '04', title: 'Follow-up operativo', text: 'Ogni lead entra in una pipeline con scoring, reminder e script di risposta rapida.' },
  { step: '05', title: 'Ottimizzazione a vendite', text: 'La settimana non si chiude sul CPL, ma su sopralluoghi, preventivi e fatturato potenziale.' },
];

const proofPoints = [
  'Niente traffico generico: keyword e creatività parlano di serramenti, non di "casa bella".',
  'Modulo breve al primo contatto, qualifica progressiva dopo la richiesta.',
  'Dashboard con costo per richiesta, costo per sopralluogo, preventivi emessi e vendite.',
  'Pagine pensate mobile-first: molti proprietari confrontano fornitori dal telefono.',
];

const proofMetrics = [
  { value: '≤ 5 min', label: 'tempo ideale di primo contatto' },
  { value: '4 campi', label: 'richiesta iniziale, poi qualifica' },
  { value: '5 KPI', label: 'da lead a vendita, non solo CPL' },
  { value: '90 giorni', label: 'ciclo minimo di validazione' },
];

const funnelSteps = [
  { label: 'Traffico', detail: 'Search, Meta, SEO locale', metric: 'Intento' },
  { label: 'Richiesta', detail: 'Modulo breve + telefono', metric: 'Lead' },
  { label: 'Qualifica', detail: 'Zona, prodotto, urgenza', metric: 'Score' },
  { label: 'Sopralluogo', detail: 'Agenda e reminder', metric: 'Appuntamento' },
  { label: 'Preventivo', detail: 'Follow-up e next action', metric: 'Valore' },
  { label: 'Vendita', detail: 'Chiusura e motivo perso', metric: 'ROI' },
];

const auditDeliverables = [
  { title: 'Mappa domanda locale', text: 'Keyword, zone servite, materiali e intenti divisi per urgenza commerciale.' },
  { title: 'Diagnosi pagina attuale', text: 'Cosa frena fiducia, richiesta preventivo e prenotazione sopralluogo su mobile.' },
  { title: 'Schema lead scoring', text: 'Regole per separare curiosi, fuori zona, cantieri piccoli e richieste ad alto margine.' },
  { title: 'Sequenza WhatsApp', text: 'Primi messaggi, domande minime, reminder e recupero preventivo dopo sopralluogo.' },
  { title: 'Cruscotto KPI', text: 'Costo richiesta, costo sopralluogo, preventivi emessi, chiusura e valore pipeline.' },
  { title: 'Piano 30 giorni', text: 'Tre priorità operative: pagina, tracking, canale da testare senza bruciare budget.' },
];

const caseNotes = [
  {
    title: 'Showroom fascia medio-alta',
    goal: 'Aumentare sopralluoghi per alluminio e legno-alluminio',
    metrics: ['Filtro budget minimo', 'Campagne per materiale', 'Follow-up 0-24h'],
  },
  {
    title: 'Installatore locale',
    goal: 'Ridurre richieste fuori zona e preventivi piccoli',
    metrics: ['Zona obbligatoria', 'Numero infissi', 'Urgenza intervento'],
  },
  {
    title: 'Rete posa certificata',
    goal: 'Separare privati, imprese e studi tecnici',
    metrics: ['Landing per audience', 'CRM per canale', 'Report settimanale'],
  },
];
---

<BaseLayout title="Marketing per infissi" description={description} site={site} schema={schema} ogImage={ogImage} preloadImage={heroImage}>
  <header class="site-header">
    <a class="brand" href="#top" aria-label={`${site.name} home`}>
      <span class="brand-logo-wrap" aria-hidden="true">
        <img src={logoImage} alt="" width="760" height="326" />
      </span>
      <span class="brand-text">{site.name}</span>
    </a>
    <nav class="desktop-nav" aria-label="Navigazione principale">
      {nav.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <a class="nav-cta" href="#contact">Audit gratuito</a>
  </header>

  <main id="top">
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-media" style={`--hero-image: url('${heroImage}')`} aria-hidden="true"></div>
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <p class="eyebrow">Per showroom, produttori e installatori di serramenti</p>
        <h1 id="hero-title" class="display">Pipeline di preventivi per serramentisti</h1>
        <p class="hero-copy">
          M2E costruisce pagine, campagne e follow-up per trasformare traffico locale in richieste qualificate, sopralluoghi e preventivi tracciati fino alla vendita.
        </p>
        <div class="hero-actions" aria-label="Azioni principali">
          <a class="button button-primary" href="#contact">Richiedi audit</a>
          <a class="button button-secondary" href="#sistema">Vedi il sistema</a>
        </div>
        <div class="proof-rail" aria-label="Standard operativi">
          {proofMetrics.map((item) => (
            <div>
              <strong>{item.value}</strong>
              <span>{item.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="strip" aria-label="Posizionamento">
      <div class="strip-inner">
        <span>Non vendiamo "visibilità".</span>
        <span>Costruiamo un sistema commerciale misurabile per richieste ad alto valore.</span>
      </div>
    </section>

    <section class="section evidence" aria-label="Prova operativa">
      <div class="container evidence-grid">
        <div>
          <p class="eyebrow">Proof stack</p>
          <h2 class="display section-title">Prima di chiedere budget, mettiamo in ordine la prova.</h2>
        </div>
        <div class="case-note-grid">
          {caseNotes.map((item) => (
            <article class="case-note">
              <p>{item.title}</p>
              <h3>{item.goal}</h3>
              <ul>
                {item.metrics.map((metric) => <li>{metric}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section thesis" id="metodo">
      <div class="container thesis-grid">
        <div>
          <p class="eyebrow">Il punto</p>
          <h2 class="display section-title">Il problema non è avere più lead. È sapere quali meritano una chiamata.</h2>
        </div>
        <div class="thesis-copy">
          <p>
            Nel mercato infissi il cliente arriva confuso: materiali, trasmittanza, bonus, posa, tempi, prezzo. Una landing moderna deve fare tre lavori prima del modulo: creare fiducia tecnica, filtrare richieste fuori target e rendere chiaro il prossimo passo.
          </p>
          <p>
            Per questo il sito non sembra una pagina da agenzia generica. Sembra un banco vendita digitale: parla di prodotti, zone, sopralluoghi, margine e follow-up.
          </p>
        </div>
      </div>
    </section>

    <section class="section funnel" aria-label="Pipeline commerciale">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">Signature system</p>
          <h2 class="display section-title">Dal clic alla vendita, ogni passaggio ha un proprietario.</h2>
          <p>Le pagine best-in-class non si limitano a generare richieste: rendono visibile dove il margine entra, dove si blocca e chi deve intervenire.</p>
        </div>
        <div class="funnel-track">
          {funnelSteps.map((step, index) => (
            <article class="funnel-step" style={`--index: ${index}`}>
              <span>{step.metric}</span>
              <h3>{step.label}</h3>
              <p>{step.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section system" id="sistema">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">Sistema</p>
          <h2 class="display section-title">Quattro pezzi, una sola pipeline</h2>
          <p>Ogni elemento è progettato per togliere attrito al cliente e togliere ambiguità al commerciale.</p>
        </div>
        <div class="system-grid">
          {services.map((service, index) => (
            <article class="system-card">
              <span>{String(index + 1).padStart(2, '0')}</span>
              <h3>{service.title}</h3>
              <p>{service.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section diagnostic" id="economia">
      <div class="container diagnostic-grid">
        <div class="diagnostic-copy">
          <p class="eyebrow">Economia del lead</p>
          <h2 class="display section-title">Il CPL da solo è una trappola educata.</h2>
          <p>
            Una richiesta da 18 euro può costare carissima se non diventa sopralluogo. Una richiesta da 70 euro può essere ottima se porta un cantiere da 12.000 euro. Qui si ragiona a margine, non a vanità.
          </p>
          <ul class="check-list">
            {proofPoints.map((point) => <li>{point}</li>)}
          </ul>
        </div>

        <div class="calculator" aria-label="Calcolatore indicativo del valore pipeline">
          <div class="calculator-header">
            <span>Simulazione mensile</span>
            <strong id="pipelineValue">€48.000</strong>
          </div>
          <label>
            Richieste qualificate
            <input id="leadRange" type="range" min="8" max="80" value="32" />
            <span id="leadLabel">32 lead</span>
          </label>
          <label>
            Tasso sopralluogo
            <input id="visitRange" type="range" min="15" max="80" value="45" />
            <span id="visitLabel">45%</span>
          </label>
          <label>
            Valore medio preventivo
            <input id="ticketRange" type="range" min="2500" max="18000" step="500" value="7500" />
            <span id="ticketLabel">€7.500</span>
          </label>
          <div class="calculator-foot">
            <span>Stima preventivi emessi</span>
            <strong id="quoteCount">6</strong>
          </div>
        </div>
      </div>
    </section>

    <section class="section channels">
      <div class="container split">
        <div class="sticky-copy">
          <p class="eyebrow">Canali</p>
          <h2 class="display section-title">La creatività cambia per intenzione, non per capriccio.</h2>
          <p>Chi cerca "preventivo infissi PVC Torino" non ha bisogno dello stesso messaggio di chi sta leggendo un post sulla bolletta o sulla riqualificazione energetica.</p>
        </div>
        <div class="channel-list">
          {channels.map((channel) => (
            <article>
              <h3>{channel.label}</h3>
              <p>{channel.value}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section deliverables">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">Cosa ricevi</p>
          <h2 class="display section-title">L’audit non finisce con una call. Finisce con materiale usabile.</h2>
          <p>Il punto non è convincerti che “serve marketing”. Il punto è uscire con decisioni: cosa misurare, cosa correggere, quale canale testare e quali richieste smettere di inseguire.</p>
        </div>
        <div class="deliverable-grid">
          {auditDeliverables.map((item) => (
            <article>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section process">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">Roadmap</p>
          <h2 class="display section-title">Cosa succede nei primi 90 giorni</h2>
        </div>
        <div class="timeline">
          {process.map((item) => (
            <article>
              <span>{item.step}</span>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section proof">
      <div class="container">
        <div class="section-head compact">
          <p class="eyebrow">Prova</p>
          <h2 class="display section-title">La pagina parla come il commerciale dovrebbe vendere.</h2>
        </div>
        <div class="testimonial-grid">
          {testimonials.map((item) => (
            <figure>
              <blockquote>{item.quote}</blockquote>
              <figcaption>
                <strong>{item.author}</strong>
                <span>{item.role} - {item.company}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section class="section faq" id="faq">
      <div class="container faq-grid">
        <div>
          <p class="eyebrow">FAQ</p>
          <h2 class="display section-title">Domande che un serramentista fa prima di firmare</h2>
        </div>
        <div class="faq-list">
          {faqs.map((item) => (
            <details>
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="section contact" id="contact">
      <div class="container contact-grid">
        <div>
          <p class="eyebrow">Audit gratuito</p>
          <h2 class="display section-title">Porta sito, campagne e processo commerciale. Guardiamo dove perde acqua.</h2>
          <p>
            In 30 minuti analizziamo offerta, pagina attuale, tracciamento, canali e follow-up. Se c’è margine per lavorare, ti diciamo da dove partire. Se non c’è, ti evitiamo una fattura inutile. Succede raramente, ma ci piace fingere di essere adulti.
          </p>
          <div class="contact-direct">
            <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>
            <a href={`tel:${site.contact.phone?.replaceAll(' ', '')}`}>{site.contact.phone}</a>
          </div>
        </div>
        <form class="lead-form" id="auditForm">
          <label>
            Azienda
            <input name="azienda" autocomplete="organization" required />
          </label>
          <label>
            Email
            <input name="email" type="email" autocomplete="email" required />
          </label>
          <label>
            Zona servita
            <input name="zona" autocomplete="address-level2" placeholder="Es. Torino e provincia" />
          </label>
          <label>
            Telefono
            <input name="telefono" type="tel" autocomplete="tel" placeholder="+39" />
          </label>
          <label>
            Cosa vuoi migliorare?
            <select name="obiettivo">
              <option>Preventivi più qualificati</option>
              <option>Più sopralluoghi</option>
              <option>Tracking e CRM</option>
              <option>Campagne Google/Meta</option>
            </select>
          </label>
          <label>
            Contesto
            <textarea name="messaggio" rows="4" placeholder="Scrivi due righe su sito, canali attivi e obiettivo commerciale."></textarea>
          </label>
          <button class="button button-primary" type="submit">Invia richiesta</button>
          <p class="form-note">Nessuna newsletter automatica. Il form prepara una richiesta email già strutturata per l’audit.</p>
        </form>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <span>{site.name}</span>
      <nav aria-label="Link footer">
        <a href={withBase('/privacy')}>Privacy</a>
        <a href={withBase('/dietro-le-quinte')}>Dietro le quinte</a>
        <a href={withBase('/llms.txt')}>llms.txt</a>
      </nav>
    </div>
  </footer>
</BaseLayout>

<script>
  const euro = new Intl.NumberFormat('it-IT', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 });
  const leadRange = document.getElementById('leadRange') as HTMLInputElement | null;
  const visitRange = document.getElementById('visitRange') as HTMLInputElement | null;
  const ticketRange = document.getElementById('ticketRange') as HTMLInputElement | null;
  const leadLabel = document.getElementById('leadLabel');
  const visitLabel = document.getElementById('visitLabel');
  const ticketLabel = document.getElementById('ticketLabel');
  const quoteCount = document.getElementById('quoteCount');
  const pipelineValue = document.getElementById('pipelineValue');

  function updateCalculator() {
    if (!leadRange || !visitRange || !ticketRange || !leadLabel || !visitLabel || !ticketLabel || !quoteCount || !pipelineValue) return;
    const leads = Number(leadRange.value);
    const visitRate = Number(visitRange.value) / 100;
    const ticket = Number(ticketRange.value);
    const quotes = Math.max(1, Math.round(leads * visitRate * 0.45));
    leadLabel.textContent = `${leads} lead`;
    visitLabel.textContent = `${Math.round(visitRate * 100)}%`;
    ticketLabel.textContent = euro.format(ticket);
    quoteCount.textContent = String(quotes);
    pipelineValue.textContent = euro.format(quotes * ticket);
  }

  [leadRange, visitRange, ticketRange].forEach((input) => input?.addEventListener('input', updateCalculator));
  updateCalculator();

  const auditForm = document.getElementById('auditForm') as HTMLFormElement | null;
  auditForm?.addEventListener('submit', (event) => {
    event.preventDefault();
    const data = new FormData(auditForm);
    const lines = [
      'Richiesta audit M2E Marketing',
      '',
      `Azienda: ${data.get('azienda') || ''}`,
      `Email: ${data.get('email') || ''}`,
      `Telefono: ${data.get('telefono') || ''}`,
      `Zona servita: ${data.get('zona') || ''}`,
      `Obiettivo: ${data.get('obiettivo') || ''}`,
      '',
      'Contesto:',
      `${data.get('messaggio') || ''}`,
    ];
    const subject = encodeURIComponent('Richiesta audit marketing infissi');
    const body = encodeURIComponent(lines.join('\n'));
    window.location.href = `mailto:audit@m2emarketing.it?subject=${subject}&body=${body}`;
  });
</script>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }

  :global(body) {
    background: #f7f4ee;
    color: #152323;
  }

  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 50;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    padding: 1rem clamp(1rem, 4vw, 3rem);
    color: #fffaf0;
    background: linear-gradient(180deg, rgba(12, 25, 26, 0.72), rgba(12, 25, 26, 0));
  }

  .brand,
  .desktop-nav,
  .nav-cta,
  .button,
  .contact-direct a {
    min-height: 44px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    font-weight: 760;
    letter-spacing: 0;
  }

  .brand-logo-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: 9.6rem;
    block-size: 3.05rem;
    padding: 0.22rem 0.5rem;
    background: rgba(255, 255, 255, 0.94);
    border: 1px solid rgba(255, 255, 255, 0.58);
  }

  .brand-logo-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .brand-text {
    color: #fffaf0;
    font-weight: 820;
  }

  .desktop-nav {
    display: flex;
    align-items: center;
    gap: clamp(0.7rem, 2vw, 1.4rem);
    color: rgba(255, 250, 240, 0.82);
    font-size: 0.86rem;
  }

  .desktop-nav a,
  .footer a {
    transition: color 180ms ease;
  }

  .desktop-nav a:hover,
  .footer a:hover {
    color: #f2b84b;
  }

  .nav-cta {
    justify-self: end;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.45);
    background: rgba(255, 255, 255, 0.1);
    color: #fffaf0;
    font-size: 0.9rem;
    font-weight: 720;
  }

  .hero {
    position: relative;
    min-height: 86vh;
    display: grid;
    align-items: end;
    overflow: hidden;
    color: #fffaf0;
    background: #102223;
  }

  .hero-media,
  .hero-overlay {
    position: absolute;
    inset: 0;
  }

  .hero-media {
    background-image: var(--hero-image);
    background-size: cover;
    background-position: center;
    transform: scale(1.02);
  }

  .hero-overlay {
    background:
      linear-gradient(90deg, rgba(10, 28, 29, 0.93) 0%, rgba(10, 28, 29, 0.74) 42%, rgba(10, 28, 29, 0.18) 76%),
      linear-gradient(0deg, rgba(10, 28, 29, 0.82) 0%, rgba(10, 28, 29, 0) 36%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    width: min(100%, 1180px);
    padding: clamp(7rem, 14vh, 11rem) clamp(1.25rem, 5vw, 4rem) clamp(2rem, 6vh, 4rem);
  }

  .eyebrow {
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #b56f32;
  }

  .hero .eyebrow {
    color: #f2b84b;
  }

  .hero h1 {
    max-width: 12.6ch;
    margin-top: 1rem;
    font-size: clamp(3.2rem, 9vw, 7.6rem);
    line-height: 0.9;
    letter-spacing: 0;
  }

  .hero-copy {
    max-width: 660px;
    margin-top: 1.3rem;
    font-size: clamp(1.05rem, 1.6vw, 1.35rem);
    line-height: 1.55;
    color: rgba(255, 250, 240, 0.86);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.8rem;
  }

  .proof-rail {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    width: min(100%, 850px);
    margin-top: 1.2rem;
    border: 1px solid rgba(255, 250, 240, 0.18);
    background: rgba(9, 29, 30, 0.44);
    backdrop-filter: blur(10px);
  }

  .proof-rail div {
    min-height: 5.4rem;
    padding: 0.82rem 0.9rem;
    border-right: 1px solid rgba(255, 250, 240, 0.14);
  }

  .proof-rail div:last-child {
    border-right: 0;
  }

  .proof-rail strong,
  .proof-rail span {
    display: block;
  }

  .proof-rail strong {
    color: #f2b84b;
    font-size: 1.02rem;
    line-height: 1.1;
  }

  .proof-rail span {
    margin-top: 0.35rem;
    color: rgba(255, 250, 240, 0.72);
    font-size: 0.78rem;
