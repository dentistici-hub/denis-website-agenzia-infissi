---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, nav, schema, services, testimonials, faqs } from '../data/placeholder';

const description = 'Landing page dimostrativa per Telaio Growth: agenzia marketing verticale per aziende di infissi e serramenti che vogliono preventivi qualificati, tracciamento e follow-up commerciale.';
const basePath = import.meta.env.BASE_URL;
const withBase = (path: string) => `${basePath.replace(/\/?$/, '/')}${path.replace(/^\//, '')}`;
const heroImage = withBase('/images/hero-showroom-pipeline.png');

const channels = [
  { label: 'Google Search', value: 'Domanda calda: sostituzione infissi, preventivo, posa certificata.' },
  { label: 'Meta locale', value: 'Domanda latente: riqualificazione, isolamento, showroom e offerte stagionali.' },
  { label: 'SEO + AI search', value: 'Contenuti utili per bonus, materiali, posa, trasmittanza e zone servite.' },
  { label: 'CRM/WhatsApp', value: 'Richieste ordinate per priorita, tempo di risposta e prossima azione.' },
];

const process = [
  { step: '01', title: 'Diagnosi del margine', text: 'Separiamo prodotti da spingere, zone da servire, cantieri da evitare e obiettivi commerciali reali.' },
  { step: '02', title: 'Pagina verticale', text: 'Costruiamo messaggio, prova, obiezioni e modulo per il tipo di richiesta che vuoi ricevere.' },
  { step: '03', title: 'Traffico misurabile', text: 'Campagne divise per intento, materiale, urgenza e area geografica. Niente calderone mistico.' },
  { step: '04', title: 'Follow-up operativo', text: 'Ogni lead entra in una pipeline con scoring, reminder e script di risposta rapida.' },
  { step: '05', title: 'Ottimizzazione a vendite', text: 'La settimana non si chiude sul CPL, ma su sopralluoghi, preventivi e fatturato potenziale.' },
];

const proofPoints = [
  'Niente traffico generico: keyword e creativita parlano di serramenti, non di "casa bella".',
  'Modulo breve al primo contatto, qualifica progressiva dopo la richiesta.',
  'Dashboard con costo per richiesta, costo per sopralluogo, preventivi emessi e vendite.',
  'Pagine pensate mobile-first: molti proprietari confrontano fornitori dal telefono.',
];
---

<BaseLayout title="Marketing per infissi" description={description} site={site} schema={schema} demoMessage="Demo landing per agenzia marketing verticale infissi. Pronta da adattare a brand, offerta e casi reali.">
  <header class="site-header">
    <a class="brand" href="#top" aria-label={`${site.name} home`}>
      <span class="brand-mark" aria-hidden="true">TG</span>
      <span>{site.name}</span>
    </a>
    <nav class="desktop-nav" aria-label="Navigazione principale">
      {nav.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <a class="nav-cta" href="#contact">Audit gratuito</a>
  </header>

  <main id="top">
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-media" style={`--hero-image: url('${heroImage}')`} aria-hidden="true"></div>
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <p class="eyebrow">Per showroom, produttori e installatori di serramenti</p>
        <h1 id="hero-title" class="display">Pipeline di preventivi per serramentisti</h1>
        <p class="hero-copy">
          Una landing page verticale, campagne misurate e follow-up commerciale per trasformare traffico locale in richieste qualificate, sopralluoghi e preventivi tracciati.
        </p>
        <div class="hero-actions" aria-label="Azioni principali">
          <a class="button button-primary" href="#contact">Richiedi audit</a>
          <a class="button button-secondary" href="#sistema">Vedi il sistema</a>
        </div>
        <div class="hero-metrics" aria-label="Metriche principali">
          <div>
            <strong>90 giorni</strong>
            <span>per validare canali, pagina e follow-up</span>
          </div>
          <div>
            <strong>5 metriche</strong>
            <span>dal lead alla vendita, non solo clic</span>
          </div>
          <div>
            <strong>1 verticale</strong>
            <span>infissi, serramenti, posa e showroom</span>
          </div>
        </div>
      </div>
    </section>

    <section class="strip" aria-label="Posizionamento">
      <div class="strip-inner">
        <span>Non vendiamo "visibilita".</span>
        <span>Costruiamo un sistema commerciale misurabile per richieste ad alto valore.</span>
      </div>
    </section>

    <section class="section thesis" id="metodo">
      <div class="container thesis-grid">
        <div>
          <p class="eyebrow">Il punto</p>
          <h2 class="display section-title">Il problema non e avere piu lead. E sapere quali meritano una chiamata.</h2>
        </div>
        <div class="thesis-copy">
          <p>
            Nel mercato infissi il cliente arriva confuso: materiali, trasmittanza, bonus, posa, tempi, prezzo. Una landing moderna deve fare tre lavori prima del modulo: creare fiducia tecnica, filtrare richieste fuori target e rendere chiaro il prossimo passo.
          </p>
          <p>
            Per questo il sito non sembra una pagina da agenzia generica. Sembra un banco vendita digitale: parla di prodotti, zone, sopralluoghi, margine e follow-up.
          </p>
        </div>
      </div>
    </section>

    <section class="section system" id="sistema">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">Sistema</p>
          <h2 class="display section-title">Quattro pezzi, una sola pipeline</h2>
          <p>Ogni elemento e progettato per togliere attrito al cliente e togliere ambiguita al commerciale.</p>
        </div>
        <div class="system-grid">
          {services.map((service, index) => (
            <article class="system-card">
              <span>{String(index + 1).padStart(2, '0')}</span>
              <h3>{service.title}</h3>
              <p>{service.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section diagnostic" id="economia">
      <div class="container diagnostic-grid">
        <div class="diagnostic-copy">
          <p class="eyebrow">Economia del lead</p>
          <h2 class="display section-title">Il CPL da solo e una trappola educata.</h2>
          <p>
            Una richiesta da 18 euro puo costare carissima se non diventa sopralluogo. Una richiesta da 70 euro puo essere ottima se porta un cantiere da 12.000 euro. Qui si ragiona a margine, non a vanita.
          </p>
          <ul class="check-list">
            {proofPoints.map((point) => <li>{point}</li>)}
          </ul>
        </div>

        <div class="calculator" aria-label="Calcolatore indicativo del valore pipeline">
          <div class="calculator-header">
            <span>Simulazione mensile</span>
            <strong id="pipelineValue">€48.000</strong>
          </div>
          <label>
            Richieste qualificate
            <input id="leadRange" type="range" min="8" max="80" value="32" />
            <span id="leadLabel">32 lead</span>
          </label>
          <label>
            Tasso sopralluogo
            <input id="visitRange" type="range" min="15" max="80" value="45" />
            <span id="visitLabel">45%</span>
          </label>
          <label>
            Valore medio preventivo
            <input id="ticketRange" type="range" min="2500" max="18000" step="500" value="7500" />
            <span id="ticketLabel">€7.500</span>
          </label>
          <div class="calculator-foot">
            <span>Stima preventivi emessi</span>
            <strong id="quoteCount">6</strong>
          </div>
        </div>
      </div>
    </section>

    <section class="section channels">
      <div class="container split">
        <div class="sticky-copy">
          <p class="eyebrow">Canali</p>
          <h2 class="display section-title">La creativita cambia per intenzione, non per capriccio.</h2>
          <p>Chi cerca "preventivo infissi PVC Torino" non ha bisogno dello stesso messaggio di chi sta leggendo un post sulla bolletta o sulla riqualificazione energetica.</p>
        </div>
        <div class="channel-list">
          {channels.map((channel) => (
            <article>
              <h3>{channel.label}</h3>
              <p>{channel.value}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section process">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">Roadmap</p>
          <h2 class="display section-title">Cosa succede nei primi 90 giorni</h2>
        </div>
        <div class="timeline">
          {process.map((item) => (
            <article>
              <span>{item.step}</span>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section proof">
      <div class="container">
        <div class="section-head compact">
          <p class="eyebrow">Prova</p>
          <h2 class="display section-title">La pagina parla come il commerciale dovrebbe vendere.</h2>
        </div>
        <div class="testimonial-grid">
          {testimonials.map((item) => (
            <figure>
              <blockquote>{item.quote}</blockquote>
              <figcaption>
                <strong>{item.author}</strong>
                <span>{item.role} - {item.company}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section class="section faq" id="faq">
      <div class="container faq-grid">
        <div>
          <p class="eyebrow">FAQ</p>
          <h2 class="display section-title">Domande che un serramentista fa prima di firmare</h2>
        </div>
        <div class="faq-list">
          {faqs.map((item) => (
            <details>
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="section contact" id="contact">
      <div class="container contact-grid">
        <div>
          <p class="eyebrow">Audit gratuito</p>
          <h2 class="display section-title">Porta sito, campagne e processo commerciale. Guardiamo dove perde acqua.</h2>
          <p>
            In 30 minuti analizziamo offerta, pagina attuale, tracciamento, canali e follow-up. Se c'e margine per lavorare, ti diciamo da dove partire. Se non c'e, ti evitiamo una fattura inutile. Succede raramente, ma ci piace fingere di essere adulti.
          </p>
          <div class="contact-direct">
            <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>
            <a href={`tel:${site.contact.phone?.replaceAll(' ', '')}`}>{site.contact.phone}</a>
          </div>
        </div>
        <form class="lead-form" action={`mailto:${site.contact.email}`} method="post" enctype="text/plain">
          <label>
            Azienda
            <input name="azienda" autocomplete="organization" required />
          </label>
          <label>
            Email
            <input name="email" type="email" autocomplete="email" required />
          </label>
          <label>
            Zona servita
            <input name="zona" autocomplete="address-level2" placeholder="Es. Torino e provincia" />
          </label>
          <label>
            Cosa vuoi migliorare?
            <select name="obiettivo">
              <option>Preventivi piu qualificati</option>
              <option>Piu sopralluoghi</option>
              <option>Tracking e CRM</option>
              <option>Campagne Google/Meta</option>
            </select>
          </label>
          <label>
            Contesto
            <textarea name="messaggio" rows="4" placeholder="Scrivi due righe su sito, canali attivi e obiettivo commerciale."></textarea>
          </label>
          <button class="button button-primary" type="submit">Invia richiesta</button>
          <p class="form-note">Nessuna newsletter automatica. Solo risposta sull'audit.</p>
        </form>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <span>{site.name}</span>
      <nav aria-label="Link footer">
        <a href={withBase('/privacy')}>Privacy</a>
        <a href={withBase('/dietro-le-quinte')}>Dietro le quinte</a>
        <a href={withBase('/llms.txt')}>llms.txt</a>
      </nav>
    </div>
  </footer>
</BaseLayout>

<script>
  const euro = new Intl.NumberFormat('it-IT', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 });
  const leadRange = document.getElementById('leadRange') as HTMLInputElement | null;
  const visitRange = document.getElementById('visitRange') as HTMLInputElement | null;
  const ticketRange = document.getElementById('ticketRange') as HTMLInputElement | null;
  const leadLabel = document.getElementById('leadLabel');
  const visitLabel = document.getElementById('visitLabel');
  const ticketLabel = document.getElementById('ticketLabel');
  const quoteCount = document.getElementById('quoteCount');
  const pipelineValue = document.getElementById('pipelineValue');

  function updateCalculator() {
    if (!leadRange || !visitRange || !ticketRange || !leadLabel || !visitLabel || !ticketLabel || !quoteCount || !pipelineValue) return;
    const leads = Number(leadRange.value);
    const visitRate = Number(visitRange.value) / 100;
    const ticket = Number(ticketRange.value);
    const quotes = Math.max(1, Math.round(leads * visitRate * 0.45));
    leadLabel.textContent = `${leads} lead`;
    visitLabel.textContent = `${Math.round(visitRate * 100)}%`;
    ticketLabel.textContent = euro.format(ticket);
    quoteCount.textContent = String(quotes);
    pipelineValue.textContent = euro.format(quotes * ticket);
  }

  [leadRange, visitRange, ticketRange].forEach((input) => input?.addEventListener('input', updateCalculator));
  updateCalculator();
</script>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }

  :global(body) {
    background: #f7f4ee;
    color: #152323;
  }

  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 50;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    padding: 1rem clamp(1rem, 4vw, 3rem);
    color: #fffaf0;
    background: linear-gradient(180deg, rgba(12, 25, 26, 0.72), rgba(12, 25, 26, 0));
  }

  .brand,
  .desktop-nav,
  .nav-cta,
  .button,
  .contact-direct a {
    min-height: 44px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    font-weight: 760;
    letter-spacing: 0;
  }

  .brand-mark {
    display: grid;
    place-items: center;
    inline-size: 2.35rem;
    block-size: 2.35rem;
    border: 1px solid rgba(255, 255, 255, 0.45);
    background: rgba(255, 255, 255, 0.1);
    font-size: 0.8rem;
  }

  .desktop-nav {
    display: flex;
    align-items: center;
    gap: clamp(0.7rem, 2vw, 1.4rem);
    color: rgba(255, 250, 240, 0.82);
    font-size: 0.86rem;
  }

  .desktop-nav a,
  .footer a {
    transition: color 180ms ease;
  }

  .desktop-nav a:hover,
  .footer a:hover {
    color: #f2b84b;
  }

  .nav-cta {
    justify-self: end;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.45);
    background: rgba(255, 255, 255, 0.1);
    color: #fffaf0;
    font-size: 0.9rem;
    font-weight: 720;
  }

  .hero {
    position: relative;
    min-height: 86vh;
    display: grid;
    align-items: end;
    overflow: hidden;
    color: #fffaf0;
    background: #102223;
  }

  .hero-media,
  .hero-overlay {
    position: absolute;
    inset: 0;
  }

  .hero-media {
    background-image: var(--hero-image);
    background-size: cover;
    background-position: center;
    transform: scale(1.02);
  }

  .hero-overlay {
    background:
      linear-gradient(90deg, rgba(10, 28, 29, 0.93) 0%, rgba(10, 28, 29, 0.74) 42%, rgba(10, 28, 29, 0.18) 76%),
      linear-gradient(0deg, rgba(10, 28, 29, 0.82) 0%, rgba(10, 28, 29, 0) 36%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    width: min(100%, 1180px);
    padding: clamp(7rem, 14vh, 11rem) clamp(1.25rem, 5vw, 4rem) clamp(2rem, 6vh, 4rem);
  }

  .eyebrow {
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #b56f32;
  }

  .hero .eyebrow {
    color: #f2b84b;
  }

  .hero h1 {
    max-width: 12.6ch;
    margin-top: 1rem;
    font-size: clamp(3.2rem, 9vw, 7.6rem);
    line-height: 0.9;
    letter-spacing: 0;
  }

  .hero-copy {
    max-width: 660px;
    margin-top: 1.3rem;
    font-size: clamp(1.05rem, 1.6vw, 1.35rem);
    line-height: 1.55;
    color: rgba(255, 250, 240, 0.86);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.8rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.86rem 1.12rem;
    border: 1px solid transparent;
    font-weight: 820;
    line-height: 1.1;
    transition: transform 180ms ease, background 180ms ease, color 180ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button-primary {
    background: #f2b84b;
    color: #102223;
  }

  .button-primary:hover {
    background: #ffd06d;
  }

  .button-secondary {
    border-color: rgba(255, 250, 240, 0.5);
    color: #fffaf0;
    background: rgba(255, 255, 255, 0.08);
  }

  .hero-metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    width: min(100%, 920px);
    margin-top: clamp(2.5rem, 7vh, 4.6rem);
    background: rgba(255, 250, 240, 0.2);
  }

  .hero-metrics div {
    padding: 1rem;
    background: rgba(9, 29, 30, 0.72);
  }

  .hero-metrics strong,
  .hero-metrics span {
    display: block;
  }

  .hero-metrics strong {
    font-size: clamp(1.15rem, 2vw, 1.7rem);
    color: #fffaf0;
  }

  .hero-metrics span {
    margin-top: 0.28rem;
    color: rgba(255, 250, 240, 0.74);
    font-size: 0.88rem;
    line-height: 1.35;
  }

  .strip {
    background: #e2f0ec;
    border-block: 1px solid rgba(16, 34, 35, 0.14);
  }

  .strip-inner {
    width: min(100%, 1180px);
    margin: 0 auto;
    padding: 1rem clamp(1.25rem, 5vw, 4rem);
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    color: #102223;
    font-weight: 760;
  }

  .section {
    padding: clamp(4rem, 9vw, 7.5rem) 0;
  }

  .container {
    width: min(100%, 1180px);
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 4rem);
  }

  .section-title {
    font-size: clamp(2rem, 4.8vw, 4.4rem);
    line-height: 0.98;
    letter-spacing: 0;
    color: #102223;
  }

  .section-head {
    max-width: 790px;
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
  }

  .section-head p:not(.eyebrow),
  .diagnostic-copy > p,
  .sticky-copy p,
  .contact p,
  .thesis-copy p {
    margin-top: 1rem;
    color: #51605c;
    line-height: 1.68;
  }

  .thesis-grid,
  .diagnostic-grid,
  .split,
  .contact-grid,
  .faq-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.92fr);
    gap: clamp(2rem, 7vw, 5rem);
    align-items: start;
  }

  .thesis-copy {
    font-size: 1.08rem;
  }

  .system {
    background: #102223;
    color: #fffaf0;
  }

  .system .section-title,
  .system .section-head p {
    color: #fffaf0;
  }

  .system-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-top: 1px solid rgba(255, 250, 240, 0.18);
    border-left: 1px solid rgba(255, 250, 240, 0.18);
  }

  .system-card {
    min-height: 21rem;
    padding: clamp(1.2rem, 2.5vw, 1.8rem);
    border-right: 1px solid rgba(255, 250, 240, 0.18);
    border-bottom: 1px solid rgba(255, 250, 240, 0.18);
  }

  .system-card span,
  .timeline span {
    display: block;
    color: #f2b84b;
    font-weight: 820;
    margin-bottom: 1.6rem;
  }

  .system-card h3,
  .channel-list h3,
  .timeline h3 {
    font-size: 1.22rem;
    line-height: 1.15;
    color: inherit;
  }

  .system-card p,
  .channel-list p,
  .timeline p {
    margin-top: 1rem;
    color: rgba(255, 250, 240, 0.72);
    line-height: 1.58;
  }

  .diagnostic {
    background: #fffaf0;
  }

  .check-list {
    list-style: none;
    display: grid;
    gap: 0.9rem;
    margin-top: 1.5rem;
  }

  .check-list li {
    position: relative;
    padding-left: 1.45rem;
    color: #263837;
    line-height: 1.55;
  }

  .check-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.62rem;
    width: 0.55rem;
    height: 0.55rem;
    background: #2e8176;
  }

  .calculator {
    padding: clamp(1.2rem, 3vw, 2rem);
    background: #102223;
    color: #fffaf0;
    border: 1px solid rgba(16, 34, 35, 0.16);
  }

  .calculator-header,
  .calculator-foot {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255, 250, 240, 0.16);
  }

  .calculator-header strong {
    font-size: clamp(1.8rem, 4vw, 3rem);
    color: #f2b84b;
  }

  .calculator label {
    display: grid;
    gap: 0.7rem;
    margin-top: 1.3rem;
    color: rgba(255, 250, 240, 0.84);
    font-weight: 720;
  }

  .calculator input[type='range'] {
    width: 100%;
    accent-color: #f2b84b;
  }

  .calculator label span {
    color: #cfe6df;
    font-weight: 520;
  }

  .calculator-foot {
    margin-top: 1.6rem;
    padding-top: 1rem;
    padding-bottom: 0;
    border-top: 1px solid rgba(255, 250, 240, 0.16);
    border-bottom: 0;
  }

  .calculator-foot strong {
    font-size: 2rem;
    color: #f2b84b;
  }

  .channels {
    background: #e8e0d2;
  }

  .sticky-copy {
    position: sticky;
    top: 7rem;
  }

  .channel-list {
    display: grid;
    gap: 1px;
    background: rgba(16, 34, 35, 0.16);
