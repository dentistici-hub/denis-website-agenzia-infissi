---
import BaseLayout from '../layouts/BaseLayout.astro';
import NavMega from '@components/navigation/NavMega.astro';
import FooterColumns from '@components/footer/FooterColumns.astro';
import { site, nav, schema, insights } from '../data/placeholder';

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  return d.toLocaleDateString(site.language === 'it' ? 'it-IT' : 'en-GB', {
    day: 'numeric', month: 'long', year: 'numeric',
  });
}

const isItalian = site.language === 'it';
const pageTitle = isItalian ? 'Approfondimenti' : 'Insights';
const eyebrow = isItalian ? 'Approfondimenti' : 'Thought Leadership';
const intro = isItalian
  ? `Guide operative su landing page, campagne, follow-up e metriche commerciali per aziende di infissi e serramenti.`
  : `Operational notes on landing pages, campaigns, follow-up, and sales metrics for window and door businesses.`;
const readLabel = isItalian ? 'Leggi l\'analisi' : 'Read full analysis';
---

<BaseLayout
  title={pageTitle}
  description={isItalian
    ? `Approfondimenti marketing di ${site.name} per aziende di infissi, serramenti, posa certificata e showroom.`
    : `Marketing insights from ${site.name} for window, door, installation, and showroom businesses.`}
  site={site}
  schema={schema}
>
  <NavMega brandName={site.name} links={nav} />

  <main class="blog-page">
    <div class="container">
      <header class="blog-page__header section">
        <p class="blog-page__eyebrow">{eyebrow}</p>
        <h1 class="blog-page__title display">{pageTitle}</h1>
        <p class="blog-page__intro">{intro}</p>
      </header>

      <div class="blog-page__grid">
        {insights.map((item, i) => (
          <article class="blog-page__article" data-animate style={`--index: ${i}`}>
            <div class="blog-page__meta">
              <span class="blog-page__category">{item.category}</span>
              <time class="blog-page__date" datetime={item.date}>{formatDate(item.date)}</time>
            </div>
            <h2 class="blog-page__article-title display">
              <a href={item.slug ? `/blog/${item.slug}` : '#'} class="blog-page__title-link">{item.title}</a>
            </h2>
            <p class="blog-page__excerpt">{item.excerpt}</p>
            {item.slug && (
              <a href={`/blog/${item.slug}`} class="blog-page__read-more" aria-label={`${readLabel}: ${item.title}`}>
                {readLabel} &rarr;
              </a>
            )}
          </article>
        ))}
      </div>
    </div>
  </main>

  <FooterColumns
    site={site}
    links={nav}
    columns={[
      {
        title: isItalian ? 'Sistema' : 'System',
        links: [
          { label: 'Landing page', href: '/#sistema' },
          { label: 'Campagne Google e Meta', href: '/#sistema' },
          { label: 'CRM e WhatsApp', href: '/#sistema' },
          { label: 'Dashboard vendite', href: '/#economia' },
        ],
      },
      {
        title: isItalian ? 'Link rapidi' : 'Quick Links',
        links: [
          { label: isItalian ? 'Metodo' : 'Method', href: '/#metodo' },
          { label: isItalian ? 'Approfondimenti' : 'Insights', href: '/blog' },
          { label: 'Audit', href: '/#contact' },
          { label: 'Privacy Policy', href: '/privacy' },
        ],
      },
    ]}
    disclaimer={isItalian
      ? 'Demo informativa per un posizionamento marketing verticale nel settore infissi. Dati e casi vanno sostituiti con risultati reali prima della pubblicazione.'
      : 'Informational demo for vertical marketing positioning in the window and door sector. Data and cases should be replaced with real results before publishing.'}
  />
</BaseLayout>

<script>
  import '../scripts/scroll-animations';
</script>

<style>
  .blog-page__header {
    max-width: 700px;
    padding-top: calc(var(--space-2xl) + 80px);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--color-border-strong, var(--color-border));
    margin-bottom: var(--space-xl);
  }

  .blog-page__eyebrow {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .blog-page__title {
    font-size: var(--text-display);
    margin-bottom: var(--space-md);
  }

  .blog-page__intro {
    font-size: var(--text-lg);
    color: var(--color-fg-muted);
    line-height: 1.6;
  }

  .blog-page__grid {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding-bottom: var(--space-2xl);
  }

  .blog-page__article {
    padding: var(--space-xl) 0;
    border-bottom: 1px solid var(--color-border);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  @media (min-width: 860px) {
    .blog-page__article {
      grid-template-columns: auto 1fr auto;
      align-items: start;
      gap: var(--space-lg);
    }
    .blog-page__meta { flex-direction: column; }
    .blog-page__article-title { grid-column: 2; grid-row: 1; }
    .blog-page__excerpt { grid-column: 2; grid-row: 2; }
    .blog-page__read-more { grid-column: 3; grid-row: 1 / 3; align-self: center; white-space: nowrap; }
  }

  .blog-page__meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  @media (min-width: 860px) {
    .blog-page__meta {
      flex-direction: column;
      align-items: flex-start;
      min-width: 100px;
    }
  }

  .blog-page__category {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    padding: 0.2rem 0.6rem;
    background: var(--color-accent-light, color-mix(in srgb, var(--color-accent) 10%, transparent));
    border-radius: 2px;
  }

  .blog-page__date {
    font-size: var(--text-xs);
    color: var(--color-fg-faint);
  }

  .blog-page__article-title {
    font-size: var(--text-xl);
    color: var(--color-fg);
    line-height: var(--leading-snug);
  }
  .blog-page__title-link {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 200ms;
  }
  .blog-page__title-link:hover { border-color: var(--color-accent); color: var(--color-accent); }

  .blog-page__excerpt {
    font-size: var(--text-base);
    color: var(--color-fg-muted);
    line-height: 1.6;
    max-width: 70ch;
  }

  .blog-page__read-more {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
    padding-bottom: 2px;
    display: inline-block;
    transition: border-color 200ms;
  }

  .blog-page__read-more:hover {
    border-color: var(--color-accent);
  }
</style>
