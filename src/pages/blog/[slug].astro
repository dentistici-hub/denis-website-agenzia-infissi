---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NavMega from '@components/navigation/NavMega.astro';
import FooterColumns from '@components/footer/FooterColumns.astro';
import { site, nav, schema, insights } from '../../data/placeholder';

export async function getStaticPaths() {
  const { insights: posts } = await import('../../data/placeholder');
  return posts
    .filter((p) => !!p.slug)
    .map((post) => ({
      params: { slug: post.slug },
      props: { post },
    }));
}

const { post } = Astro.props;

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  return d.toLocaleDateString(site.language === 'it' ? 'it-IT' : 'en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

const paragraphs = (post.body ?? post.excerpt).split(/\n+/);
---

<BaseLayout
  title={post.title}
  description={post.excerpt}
  site={site}
  schema={schema}
>
  <NavMega brandName={site.name} links={nav} />

  <main class="post">
    <article class="post__article container">
      <header class="post__header">
        <p class="post__eyebrow">
          <a href="/blog" class="post__back">{site.language === 'it' ? 'Tutti gli approfondimenti' : 'All insights'}</a>
        </p>
        <div class="post__meta">
          <span class="post__category">{post.category}</span>
          <time class="post__date" datetime={post.date}>{formatDate(post.date)}</time>
        </div>
        <h1 class="post__title display">{post.title}</h1>
      </header>

      <div class="post__body">
        {paragraphs.map((para) => <p>{para}</p>)}
      </div>
    </article>
  </main>

  <FooterColumns site={site} links={nav} />
</BaseLayout>

<script>
  import '../../scripts/scroll-animations';
</script>

<style>
  .post__article {
    padding-top: calc(var(--space-2xl) + 80px);
    padding-bottom: var(--space-2xl);
    max-width: 800px;
  }
  .post__header {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-xl);
    margin-bottom: var(--space-xl);
  }
  .post__eyebrow {
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
    margin-bottom: var(--space-md);
  }
  .post__back {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid currentColor;
  }
  .post__back:hover { color: var(--color-accent); }
  .post__meta {
    display: flex;
    gap: var(--space-md);
    align-items: center;
    margin-bottom: var(--space-md);
    flex-wrap: wrap;
  }
  .post__category {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    padding: 0.2rem 0.6rem;
    background: var(--color-accent-light, color-mix(in srgb, var(--color-accent) 10%, transparent));
    border-radius: 2px;
  }
  .post__date { font-size: var(--text-sm); color: var(--color-fg-muted); }
  .post__title {
    font-size: var(--text-3xl);
    line-height: var(--leading-tight);
    color: var(--color-fg);
  }
  .post__body p {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-fg);
    margin-bottom: var(--space-md);
    max-width: 70ch;
  }
</style>
